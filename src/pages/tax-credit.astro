---
import { getEntry } from 'astro:content';

import HowItWorks from '@/components/blocks/how-it-works.astro';
import TaxCreditHero from '@/components/blocks/tax-credit-hero.astro';
import TrustedByThousands from '@/components/blocks/trusted-by-thousands.astro';
import DefaultLayout from '@/layouts/DefaultLayout.astro';

const heroEntry        = await getEntry('taxCreditHero',      'index');
const howItWorksEntry  = await getEntry('howItWorks',         'index');
const trustedByEntry   = await getEntry('trustedByThousands', 'index');
---

<DefaultLayout
  title="Get Your Schedule R Tax Credit Certificate Online Today"
  description="We provide the physician-signed IRS forms required for your disability tax credit. 100% Online, Same-Day Delivery, Lowest Cost in the US."
>
  {heroEntry && (
    <TaxCreditHero {...heroEntry.data} />
  )}

  {howItWorksEntry && (
    <HowItWorks {...howItWorksEntry.data} />
  )}

  {trustedByEntry && (
    <TrustedByThousands {...trustedByEntry.data} />
  )}
</DefaultLayout>
