---
import { getEntry } from 'astro:content';

import GuidesHero from '@/components/blocks/guides-hero.astro';
import WhyGuides from '@/components/blocks/why-guides.astro';
import DefaultLayout from '@/layouts/DefaultLayout.astro';

const guidesHeroEntry = await getEntry('guidesHero', 'index');
const whyGuidesEntry  = await getEntry('whyGuides',  'index');
---

<DefaultLayout
  title="Guides to Simplify Disability Parking Permits | ParkingMD"
  description="Step-by-step guides to help you apply for, renew, and understand disability parking permits and state regulations."
>
  {guidesHeroEntry && <GuidesHero {...guidesHeroEntry.data} />}
  {whyGuidesEntry  && <WhyGuides  {...whyGuidesEntry.data}  />}
</DefaultLayout>
